---
import "../styles/global.css";
import { HwcMap } from "@hwc/map";
import {HwcHeader } from "@hwc/header";
import { MdExitToApp } from "react-icons/md";
import { envField } from "astro/config";

const key = import.meta.env.PUBLIC_MAPTILER_API_KEY;

const items = [
  { id: "a", lat: 38.0, lon: -87.5, name: "A" },
  { id: "b", lat: 38.02, lon: -87.52, name: "B" }
];
---
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/ico+xml" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Photo Log | Crawfordsville Market Street</title>
	</head>
	<body>
        <HwcHeader client:only="react" title="Crawfordsville Market Street RR Grade Seperation"/>
        <div style="height: 93vh;">
            <HwcMap client:only="react" items={items} mapTilerKey={key} />
        </div>
	</body>
</html>